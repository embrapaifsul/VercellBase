<%-include('../cabecalho.ejs')%>
<h1>Listagem de Alunos</h1>
<div class="search">
    <form  method="post">
        <input type="text" name="pesquisar" placeholder="pesquisar...">
        <button type="submit" class="btn search"><i class="fa fa-search" ></i>&nbsp;pesquisar</button>
    </form>
</div>
<table>
    <thead>
        <tr>
            <td>Nome</td>
            <td>Matrícula</td>
            <td>Ações</td>
        </tr>
    </thead>
    <%for(const {id, nome, matricula} of Alunos){%>
    <tr>
        <td><%=nome%></td>
        <td><%=matricula%></td>
        <td><a href="/aluno/del/<%=id%>" class="btn delete"><i class="fas fa-trash"></i>&nbsp;Excluir</a>
            <a href="/aluno/edt/<%=id%>" class="btn edit"><i class="fas fa-edit"></i>&nbsp;Editar</a>
        </td>
    </tr>
    <%}%>

</table>
 <div class="footer"><a href="/aluno/add" class="btn add"><i class="fas fa-add"></i>&nbsp; Novo</a></div>

<%-include('../rodape.ejs')%>