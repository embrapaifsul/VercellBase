<%-include('../cabecalho.ejs')%>
<h1>Listagem de Cursos</h1>
<div class="search">
    <form  method="post">
        <input type="text" name="pesquisar" placeholder="pesquisar...">
        <button type="submit">pesquisar</button>
    </form>
</div>
<table>
    <thead>
        <tr>
            <td>Nome</td>
           
            <td>Ações</td>
        </tr>
    </thead>
    <%for(const {id, nome} of Cursos){%>
    <tr>
        <td><%=nome%></td>
        <td><a href="/curso/del/<%=id%>" class="btn delete">Excluir</a>
        <a href="/curso/edt/<%=id%>" class="btn edit">Editar</a>
        </td>
    </tr>
    <%}%>

</table>
 <div class="footer"><a href="/curso/add" class="btn add">+ Adicionar</a></div>

<%-include('../rodape.ejs')%>